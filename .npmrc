# npm security best practices
# Source: https://github.com/lirantal/npm-security-best-practices

# Block git-hosted dependencies (supply chain protection)
allow-git=none

# Audit on install
audit=true

# Disable automatic installation of peer dependencies (supply chain protection)
auto-install-peers=false

# Legacy/camelCase variant for peer auto-install toggle
autoInstallPeers=false

# Enforce Node and package manager engine constraints from package metadata
engine-strict=true

# Disable funding messages (supply chain protection)
fund=false

# Disable post-install scripts from dependencies (supply chain protection)
# See: https://cheatsheetseries.owasp.org/cheatsheets/NPM_Security_Cheat_Sheet.html#3-minimize-attack-surfaces-by-ignoring-run-scripts
ignore-scripts=true

# Avoid embedding tarball URLs in lockfile entries
lockfile-include-tarball-url=false

# Block installs of versions newer than this age in minutes (10080 = 7 days)
minimum-release-age=10080

# Require using the declared package manager
package-manager-strict=true

# Require using the exact declared package manager version
package-manager-strict-version=true

# Prefer lockfile-only resolution and fail when lockfile is out of date
prefer-frozen-lockfile=true

# Pin newly added dependency versions exactly (no range prefix)
save-exact=true

# Fail install on peer dependency conflicts
strict-peer-dependencies=true

# Verify package contents in store against integrity metadata strictly
strict-store-pkg-content-check=true

# Disable update check notifications
update-notifier=false

# Verify package integrity when reading from store/cache
verify-store-integrity=true
